import os
from dotenv import load_dotenv
from google import genai
from pinecone import Pinecone

# 1. Load the variables from the .env file
load_dotenv()

# 2. Fetch the keys from the environment
GEMINI_KEY = os.getenv("GEMINI_API_KEY")
PINECONE_KEY = os.getenv("PINECONE_API_KEY")
INDEX_NAME = os.getenv("PINECONE_INDEX_NAME")

def test_connections():
    print("🔍 Testing API Connections...")
    
    try:
        # Test Gemini
        print("📡 Connecting to Gemini...")
        client = genai.Client(api_key=GEMINI_KEY)
        test_embed = client.models.embed_content(
            model="gemini-embedding-001",
            contents="Testing the new key connection.",
            config={"output_dimensionality": 1536}
        )
        print("✅ Gemini API: SUCCESS! (Embedding generated)")

        # Test Pinecone
        print("📡 Connecting to Pinecone...")
        pc = Pinecone(api_key=PINECONE_KEY)
        index = pc.Index(INDEX_NAME)
        stats = index.describe_index_stats()
        print(f"✅ Pinecone API: SUCCESS! (Found {stats['total_vector_count']} vectors in index)")
        
        print("\n✨ All systems go! You are safe to resume your main script.")

    except Exception as e:
        print(f"\n❌ Connection Failed: {e}")
        print("Check if your .env variable names match the ones in this script!")

if __name__ == "__main__":
    test_connections()
